post_install() {
  cat <<'EOF'
==> wireplumber-lhdc-config installed.
==> Restart the user WirePlumber service to load LHDC v5 support:
    systemctl --user daemon-reload
    systemctl --user restart wireplumber
==> Reconnect the Bluetooth headset after restarting WirePlumber.
EOF
}

post_upgrade() {
  post_install
}
